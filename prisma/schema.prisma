// schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String       @id @default(uuid())
  fullName     String
  email        String       @unique
  passwordHash String
  role         Role
  profilePic   String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  skills       UserSkill[]
  projects     ProjectAssignment[]
  notifications Notification[]
  applications Application[]
}

enum Role {
  STUDENT
  MENTOR
  COMPANY
}

model Skill {
  id             String      @id @default(uuid())
  name           String
  category       String
  difficultyLevel Int
  createdAt      DateTime    @default(now())
  userSkills     UserSkill[]
}

model UserSkill {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  skill     Skill    @relation(fields: [skillId], references: [id])
  skillId   String
  level     Int
  verified  Boolean  @default(false)
  score     Float
  updatedAt DateTime @updatedAt

  @@unique([userId, skillId])
}

model Project {
  id          String                @id @default(uuid())
  name        String
  description String
  difficultyLevel Int
  createdBy   String
  type        ProjectType
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  assignments ProjectAssignment[]
}

enum ProjectType {
  INDIVIDUAL
  TEAM
}

model ProjectAssignment {
  id               String   @id @default(uuid())
  project          Project  @relation(fields: [projectId], references: [id])
  projectId        String
  user             User     @relation(fields: [userId], references: [id])
  userId           String
  role             String
  performanceScore Float
  completed        Boolean  @default(false)
  completedAt      DateTime?
}

model Company {
  id        String       @id @default(uuid())
  name      String
  industry  String
  website   String?
  createdAt DateTime     @default(now())
  jobOpenings JobOpening[]
}

model JobOpening {
  id             String      @id @default(uuid())
  company        Company     @relation(fields: [companyId], references: [id])
  companyId      String
  title          String
  description    String
  requiredSkills Json
  minExperience  Int
  salaryRange    Json
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  applications   Application[]
}

model Application {
  id       String   @id @default(uuid())
  job      JobOpening @relation(fields: [jobId], references: [id])
  jobId    String
  user     User      @relation(fields: [userId], references: [id])
  userId   String
  status   ApplicationStatus @default(APPLIED)
  score    Float?
  appliedAt DateTime  @default(now())
}

enum ApplicationStatus {
  APPLIED
  INTERVIEW
  HIRED
  REJECTED
}

model Notification {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  type      NotificationType
  content   String
  read      Boolean   @default(false)
  createdAt DateTime  @default(now())
}

enum NotificationType {
  SKILL_UPDATE
  PROJECT_UPDATE
  JOB_ALERT
  NEWS
}

model AIAgent {
  id          String   @id @default(uuid())
  type        AgentType
  description String?
  status      Boolean @default(true)
}

enum AgentType {
  EVALUATOR
  MENTOR
  MARKET
  CAREER_COACH
}